{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": [
        "CRON_SECRET",
        "NEXT_PUBLIC_POSTHOG_HOST",
        "NEXT_PUBLIC_POSTHOG_TOKEN"
      ]
    },
    "dev": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "passThroughEnv": [
        "CRON_SECRET",
        "NEXT_PUBLIC_POSTHOG_HOST",
        "NEXT_PUBLIC_POSTHOG_TOKEN"
      ]
    }
  }
}
