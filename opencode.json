{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "heroui-pro": {
      "type": "remote",
      "url": "https://mcp.heroui.pro/mcp",
      "headers": {
        "x-heroui-personal-token": "{env:HEROUI_PERSONAL_TOKEN}"
      }
    },
    "heroui-react": {
      "type": "local",
      "command": ["bunx", "-y", "@heroui/react-mcp@latest"]
    }
  }
}
