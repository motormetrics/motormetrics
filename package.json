{
  "name": "motormetrics",
  "version": "4.68.0",
  "description": "Monorepo for MotorMetrics",
  "author": "Ru Chern Chong <ruchern.chong@motormetrics.app>",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "start": "turbo start",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "migrate": "turbo migrate",
    "migrate:check": "turbo migrate:check",
    "prepare": "husky",
    "release": "semantic-release",
    "build:web": "turbo run @motormetrics/web#build",
    "dev:web": "turbo run @motormetrics/web#dev",
    "test:web": "turbo run @motormetrics/web#test",
    "test:integration:web": "turbo run @motormetrics/web#test:integration",
    "lint:web": "turbo run @motormetrics/web#lint",
    "typecheck:web": "turbo run @motormetrics/web#typecheck",
    "start:web": "turbo run @motormetrics/web#start",
    "db:migrate": "turbo run @motormetrics/database#migrate",
    "db:check": "turbo run @motormetrics/database#check",
    "db:generate": "turbo run @motormetrics/database#generate",
    "db:push": "turbo run @motormetrics/database#push",
    "db:drop": "turbo run @motormetrics/database#drop",
    "auth:generate": "turbo run auth:generate"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "semantic-release": "25.0.3",
    "turbo": "2.9.12",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,json,jsonc}": [
      "pnpm biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "pnpm@11.1.1"
}
