{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@web/*": ["./apps/web/src/*"],
      "@logos/*": ["./packages/logos/src/*"],
      "@utils/*": ["./packages/utils/src/*"]
    },
    "types": ["node"]
  }
}
