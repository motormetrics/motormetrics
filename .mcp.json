{
  "mcpServers": {
    "heroui-pro": {
      "type": "http",
      "url": "https://mcp.heroui.pro/mcp",
      "headers": {
        "x-heroui-personal-token": "${HEROUI_PERSONAL_TOKEN}"
      }
    },
    "heroui-react": {
      "command": "bunx",
      "args": ["-y", "@heroui/react-mcp@latest"]
    },
    "motormetrics": {
      "command": "bunx",
      "args": ["-y", "@motormetrics/mcp"]
    },
    "posthog": {
      "url": "https://mcp.posthog.com/mcp",
      "headers": {
        "Authorization": "Bearer ${POSTHOG_PERSONAL_API_KEY}"
      }
    },
    "sonarqube": {
      "type": "http",
      "url": "https://api.sonarcloud.io/mcp",
      "headers": {
        "Authorization": "Bearer ${SONARQUBE_TOKEN}",
        "SONARQUBE_ORG": "motormetrics"
      }
    }
  }
}
